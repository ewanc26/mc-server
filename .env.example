# ┌─────────────────────────────────────────────┐
# │  Minecraft Server — Environment Reference   │
# │  Copy to .env and fill in your values       │
# └─────────────────────────────────────────────┘

# ── Java & Minecraft Version ──────────────────
MC_IMAGE_TAG=java25
MC_VERSION=26.1.2

# ── playit.gg Tunnel ──────────────────────────
# Get your secret key at https://playit.gg/account/agents/new-docker
PLAYIT_SECRET=your-playit-secret-here

# ── JVM Options ───────────────────────────────
# Optimized for java25 with Aikar's flags
MC_JVM_OPTS=-XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8M -XX:G1ReservePercent=20 -XX:G1HeapWastePercent=5 -XX:G1MixedGCCountTarget=4 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1RSetUpdatingPauseTimePercent=5 -XX:SurvivorRatio=32 -XX:+PerfDisableSharedMem -XX:MaxTenuringThreshold=1 -XX:+UseStringDeduplication

# ── Memory ────────────────────────────────────
MC_INIT_MEMORY=256M
MC_MAX_MEMORY=1280M

# ── Server Identity ───────────────────────────
# MC_SERVER_NAME=Ewan's Minecraft Server
# MC_MOTD=A small private server for friends

# ── Gameplay ──────────────────────────────────
MC_DIFFICULTY=easy
MC_GAMEMODE=survival
MC_PVP=false
MC_HARDCORE=false
MC_ONLINE_MODE=true
MC_VIEW_DISTANCE=4
MC_SIMULATION_DISTANCE=3
MC_MAX_PLAYERS=6
MC_IDLE_TIMEOUT=5

# ── Whitelist ─────────────────────────────────
MC_ENABLE_WHITELIST=true
MC_WHITELIST=uuid1,uuid2,uuid3
MC_OPS=uuid1,uuid2,uuid3

# ── World ─────────────────────────────────────
# MC_LEVEL_NAME=world
# MC_LEVEL_TYPE=minecraft:normal
# MC_LEVEL_SEED=

# ── RCON (required for backups) ───────────────
MC_ENABLE_RCON=true
MC_RCON_PASSWORD=your-rcon-password-here

# ── Modrinth Plugins ──────────────────────────
# Auto-downloaded on container start. Add or remove slugs as needed.
# Available at: https://modrinth.com/plugins
MC_MODRINTH_PROJECTS=veinminer,luckperms,simple-voice-chat,treetimber,viaversion,viabackwards,chunky,axgraves,singleplayersleep,fodrops,maxtools,essentialsx?,coreprotect?,bluemap?,spark?

# ── Bedrock Support (Geyser/Floodgate) ────────
# Direct-download plugin URLs (comma or newline delimited).
# Requires a separate playit.gg "Minecraft Bedrock" tunnel — see docs/playit.md
# MC_PLUGINS=https://download.geysermc.org/v2/projects/geyser/versions/latest/builds/latest/downloads/spigot,https://download.geysermc.org/v2/projects/floodgate/versions/latest/builds/latest/downloads/spigot

# ── Spigot Plugins (Spiget resource IDs) ──────
# 1997=ProtocolLib  59773=ChestSort  131972=RezzLoaders
MC_SPIGET_RESOURCES=1997,59773,131972

# ── Data Directories ──────────────────────────
# MC_DATA_DIR=/Volumes/Storage/Server/MC/data
# MC_BACKUP_DIR=/Volumes/Storage/Server/MC/backups

# ── Container ─────────────────────────────────
# MC_IMAGE=itzg/minecraft-server:java25
# MC_CONTAINER_NAME=mc
# MC_RESTART_POLICY=unless-stopped
# MC_SERVER_PORT=25565
# MC_RCON_PORT=25575
# MC_VOICE_PORT=24454
# MC_BEDROCK_PORT=19132
# MC_CPU_LIMIT=2.0
# MC_CPU_RESERVE=0.5

# ── Backup ────────────────────────────────────
# Backups run every 6h with 7-day retention
# RCON_HOST/RCON_PORT/RCON_PASSWORD set in compose.yml
# MC_BACKUP_PAUSE_IF_NO_PLAYERS=true   — skip backups while the server is empty (nothing can have changed)
# MC_BACKUP_PLAYERS_CHECK_INTERVAL=5m  — how often to recheck for players while paused
