# =============================================================================
# Ewan's Minecraft Server — environment configuration
# Copy this file to .env and fill in the required values.
# Lines prefixed with # are comments and have no effect.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Minecraft version to run. Must be set before starting the server.
# Run: MC_VERSION=1.21.1 ./scripts/auto_configure.sh
MC_VERSION=

# Secret key for the playit.gg tunnel agent.
# Leave blank on first run — the agent will print a claim URL.
# After claiming, paste the secret from the playit dashboard here.
PLAYIT_SECRET=

# -----------------------------------------------------------------------------
# Server identity
# -----------------------------------------------------------------------------

MC_SERVER_NAME=Ewan's Minecraft Server
MC_MOTD=A Minecraft Server

# -----------------------------------------------------------------------------
# Gameplay
# -----------------------------------------------------------------------------

# peaceful, easy, normal, hard
MC_DIFFICULTY=easy
MC_DIFFICULTY_LOCK=false

# survival, creative, adventure, spectator
MC_GAMEMODE=survival
MC_FORCE_GAMEMODE=false

MC_HARDCORE=false
MC_PVP=false

# Set to false for a cracked/offline server (not recommended)
MC_ONLINE_MODE=true

# -----------------------------------------------------------------------------
# Players
# -----------------------------------------------------------------------------

MC_MAX_PLAYERS=6
MC_IDLE_TIMEOUT=5

MC_ENABLE_WHITELIST=true

# Comma-separated UUIDs (use https://mcuuid.net to look them up)
MC_WHITELIST=
MC_OPS=

# -----------------------------------------------------------------------------
# World
# -----------------------------------------------------------------------------

MC_LEVEL_NAME=world
# Leave blank for a random seed
MC_LEVEL_SEED=
# minecraft:normal, minecraft:flat, minecraft:large_biomes, minecraft:amplified
MC_LEVEL_TYPE=minecraft:normal
MC_ALLOW_NETHER=true
MC_GENERATE_STRUCTURES=true

# -----------------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------------

MC_VIEW_DISTANCE=4
MC_SIMULATION_DISTANCE=3

# -----------------------------------------------------------------------------
# Data paths
# -----------------------------------------------------------------------------

MC_DATA_DIR=/Volumes/Storage/Server/MC/data
MC_BACKUP_DIR=/Volumes/Storage/Server/MC/backups

# -----------------------------------------------------------------------------
# Docker image
# -----------------------------------------------------------------------------

# arm64 (Apple Silicon / Raspberry Pi) — default
MC_IMAGE=itzg/minecraft-server:java21-arm64

# Uncomment for x86_64:
# MC_IMAGE=itzg/minecraft-server:java21

# Server type: PAPER, VANILLA, FABRIC, FORGE
MC_TYPE=PAPER

# -----------------------------------------------------------------------------
# RCON (disabled by default)
# -----------------------------------------------------------------------------

MC_ENABLE_RCON=false
MC_RCON_PASSWORD=
MC_RCON_PORT=25575

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------

MC_TIMEZONE=Europe/London
MC_ENABLE_ROLLING_LOGS=true
